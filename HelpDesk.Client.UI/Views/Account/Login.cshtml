@model HelpDesk.Client.Business.ViewModels.UserLoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Login.cshtml";
}

<div class="login-box">
    <div class="login-logo">
        <a href="../../index2.html"><b>Help Desk</b></a>
    </div>
    <div class="login-box-body">
        <p class="login-box-msg">Sign in to start your session</p>
        <form asp-controller="Account" asp-action="Login" method="post">
            <div class="form-group has-feedback">
                <input type="email" class="form-control" placeholder="Email" asp-for="@Model.UserLogin.Email" value="alariosacevedo@gmail.com">
                <span class="glyphicon glyphicon-envelope form-control-feedback"></span>
                <span asp-validation-for="@Model.UserLogin.Email" class="text-red"></span>
            </div>

            <div class="form-group has-feedback">
                <input type="password" class="form-control" placeholder="Password" asp-for="@Model.UserLogin.Password" value="@Model.UserLogin.Password">
                <span class="glyphicon glyphicon-lock form-control-feedback"></span>
                <span asp-validation-for="@Model.UserLogin.Password" class="text-red"></span>
            </div>

            <div class="row">
                <div class="col-xs-8">
                    <div class="checkbox icheck">
                        <label>
                            <input type="checkbox"> Remember Me
                        </label>
                    </div>
                </div>
                <div class="col-xs-4">
                    <button type="submit" class="btn btn-primary btn-block btn-flat">Sign In</button>
                </div>
            </div>
        </form>       
        <a asp-controller="Account" asp-action="ForgotPassword">I forgot my password</a><br>
        <a asp-controller="Account" asp-action="Register" class="text-center">Register a new membership</a>
    </div>
</div>