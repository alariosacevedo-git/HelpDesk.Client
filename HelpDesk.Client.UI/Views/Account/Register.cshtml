@model HelpDesk.Client.Business.ViewModels.UserRegistrationViewModel
@using Microsoft.Extensions.Configuration
@inject IConfiguration _configuration

@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_Register.cshtml";
}

<script type="text/javascript" language="javascript">
    var baseUrl = "@_configuration["HelpDeskClientSettings:HelpDeskClientUrl"]";
    console.log("baseUrl: " + baseUrl);
</script>

<div class="register-box">
    <div class="register-logo">
        <a href="#"><b>Help Desk</b></a>
    </div>
    <div class="register-box-body">
        <p class="login-box-msg">Register a new membership - @await Component.InvokeAsync("EnvironmentName")</p>
        <form asp-controller="Account" asp-action="Register" method="post">
            
            <div class="form-group has-feedback">
                <input type="text" class="form-control" placeholder="First Name" asp-for="@Model.UserRegistration.FirstName" required>
                <span class="glyphicon glyphicon-user form-control-feedback"></span>
                <span asp-validation-for="@Model.UserRegistration.FirstName" class="text-red"></span>
            </div>

            <div class="form-group has-feedback">
                <input type="text" class="form-control" placeholder="Last Name" asp-for="@Model.UserRegistration.LastName" required>
                <span class="glyphicon glyphicon-user form-control-feedback"></span>
                <span asp-validation-for="@Model.UserRegistration.LastName" class="text-red"></span>
            </div>
            
            <div class="form-group has-feedback">
                <input type="email" class="form-control" placeholder="Email" asp-for="@Model.UserRegistration.Email" required>
                <span class="glyphicon glyphicon-envelope form-control-feedback"></span>
                <span asp-validation-for="@Model.UserRegistration.Email" class="text-red"></span>
            </div>

            <div class="form-group has-feedback">
                <input type="text" class="form-control" placeholder="Mobile Number (XXX)-XXX-XXXX" asp-for="@Model.UserRegistration.PhoneNumber" data-inputmask="'mask': ['(999)-999-9999']" data-mask required>
                <span class="glyphicon glyphicon-phone form-control-feedback"></span>
                <span asp-validation-for="@Model.UserRegistration.PhoneNumber" class="text-red"></span>
            </div>
            
            <div class="form-group has-feedback">
                <input type="password" class="form-control" placeholder="Password" asp-for="@Model.UserRegistration.Password" value="@Model.UserRegistration.Password" required>
                <span class="glyphicon glyphicon-lock form-control-feedback"></span>
                <span asp-validation-for="@Model.UserRegistration.Password" class="text-red"></span>
            </div>
            
            <div class="form-group has-feedback">
                <input type="password" class="form-control" placeholder="Retype password" asp-for="@Model.UserRegistration.ConfirmPassword" value="@Model.UserRegistration.ConfirmPassword" required>
                <span class="glyphicon glyphicon-lock form-control-feedback"></span>
                <span asp-validation-for="@Model.UserRegistration.ConfirmPassword" class="text-red"></span>
            </div>
            
            <div class="row">
                <div class="col-xs-8">
                    <div class="checkbox icheck">
                        <label>
                            <input type="checkbox"> I agree to the <a href="#">terms</a>
                        </label>
                    </div>
                </div>
                <div class="col-xs-4">
                    <button type="submit" class="btn btn-primary btn-block btn-flat">Register</button>
                </div>
            </div>
        </form>

        <a asp-controller="Account" asp-action="Login" class="text-center">I already have a membership</a>

        @if (Model.IdentityResult.Errors.Count() > 0)
        {
            <hr />
            @await Html.PartialAsync("~/Views/Shared/_IdentityResult.cshtml", Model.IdentityResult)
        }

        @if (string.IsNullOrEmpty(Model.HttpClientError) == false)
        {
            <div class="alert alert-danger alert-dismissible">
                <button type="button" class="close" data-dismiss="alert" aria-hidden="true">×</button>
                <h4><i class="icon fa fa-ban"></i> Alert!</h4>
                @Model.HttpClientError
            </div>
        }
    </div>
</div>

@if (@Model.IsUserCreated == true)
{
    <script type="text/javascript" language="javascript">
        $(document).ready(function () {
            Swal.fire({
                icon: "success",
                title: "User Registered",
                text: "User has been registered successfully, you will receive en email confirmation.",
                showConfirmButton: false,
                footer: '<a href="/Account/Login">Go to Login page</a>'
            });
        });
    </script>
}