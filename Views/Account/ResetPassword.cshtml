@model HelpDesk.Client.Business.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_ResetPassword.cshtml";
}

<div class="register-box">
    <div class="register-logo">
        <a href="../../index2.html"><b>Help Desk</b></a>
    </div>
    <div class="register-box-body">
        <p class="login-box-msg">Reset Password</p>
        <form asp-controller="Account" asp-action="ResetPassword" method="post">       
            <div class="form-group has-feedback">
                <input type="password" class="form-control" placeholder="Password" asp-for="@Model.ResetPassword.Password" value="@Model.ResetPassword.Password" required>
                <span class="glyphicon glyphicon-lock form-control-feedback"></span>
                <span asp-validation-for="@Model.ResetPassword.Password" class="text-red"></span>
            </div>
            
            <div class="form-group has-feedback">
                <input type="password" class="form-control" placeholder="Retype password" asp-for="@Model.ResetPassword.ConfirmPassword" value="@Model.ResetPassword.ConfirmPassword" required>
                <span class="glyphicon glyphicon-lock form-control-feedback"></span>
                <span asp-validation-for="@Model.ResetPassword.ConfirmPassword" class="text-red"></span>
            </div>
            
            <div class="row">
                <div class="col-xs-8">
                    
                </div>
                <div class="col-xs-4">
                    <button type="submit" class="btn btn-primary btn-block btn-flat">Change</button>
                </div>
            </div>
        </form>
    </div>
</div>


